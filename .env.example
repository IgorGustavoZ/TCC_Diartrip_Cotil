# Banco de dados
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=diartrip

# Autenticação JWT
SECRET_KEY=
ALGORITHM=HS256

# Integração com IA (OpenRouter)
OPENROUTER_API_KEY=
IA_MODEL=mistralai/mistral-7b-instruct:free

# CORS — separar múltiplas origens por vírgula
ALLOWED_ORIGINS=http://127.0.0.1:8000

# Redis — blacklist de tokens e rate limiting distribuído (opcional em dev)
REDIS_URL=redis://localhost:6379/0

# Cloudinary — armazenamento de imagens na nuvem
# Crie conta grátis em https://cloudinary.com e copie as credenciais do dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
