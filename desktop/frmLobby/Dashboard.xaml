<Window x:Class="WindowLobby.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        WindowState="Maximized"
        Background="#0F172A" Height="1011" Width="1499">

    <Grid Height="689" Width="938">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="#111827" Margin="10,20,49,20">

            <StackPanel Margin="20">

                <TextBlock Text="DiarTrip"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,40"/>

                <Button Content="👥 Usuários"
                        Height="55"
                        Margin="0,10,0,0"
                        Click="BtnUsuarios_Click"/>

                <Button Content="✈ Viagens"
                        Height="55"
                        Margin="0,10,0,0"
                        Click="BtnViagens_Click"/>

                <Button Content="⚙ Configurações"
                        Height="55"
                        Margin="0,10,0,0"
                        Click="BtnConfiguracoes_Click"/>

                <Button x:Name="BtnExpPdf" Content="📄 Exportar PDF"
                    Height="55"
                    Margin="0,10,0,0"
                    Click="BtnExpPdf_Click"/>

                <Button Content="🚪 Sair"
                        Height="55"
                        Margin="0,30,0,0"
                        Background="#7F1D1D"
                        Foreground="White"
                        Click="BtnLogout_Click"/>

            </StackPanel>

        </Border>

        <!-- ÁREA PRINCIPAL -->

        <Grid Grid.Column="1"
              Margin="20,20,-44,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Grid Margin="0,0,10,164" Grid.RowSpan="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel RenderTransformOrigin="0.516,0.159" Margin="59,0,0,19">

                    <TextBlock Text="Dashboard"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Painel administrativo"
                               Foreground="#94A3B8"
                               FontSize="16"/>

                </StackPanel>

                <Border Grid.Column="1"
                        Width="180"
                        Height="50"
                        CornerRadius="12"
                        Background="#1E293B">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="15,0">

                        <Border Width="30"
                        Height="30"
                        CornerRadius="0"
                        BorderBrush="#3B82F6"
                        BorderThickness="1">

                        <Image x:Name="imgPerfil"
                           Stretch="Fill"/>
                        </Border>

                        <TextBlock Name="txtUsuario"
                                   Text="Admin"
                                   Foreground="White"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- CARDS -->

            <UniformGrid Grid.Row="1"
                         Columns="3"
                         Margin="0,84,-96,48">

                <Border Background="#1E293B"
                        CornerRadius="15"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="Viagens"
                                   Foreground="#CBD5E1"/>

                        <TextBlock x:Name="txtViagens"
                                   Text="0"
                                   FontSize="40"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

                <Border Background="#1E293B"
                        CornerRadius="15"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="Usuários"
                                   Foreground="#CBD5E1"/>

                        <TextBlock Text="0"
                                   FontSize="40"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Name="txtUsuarios"
                                   />

                    </StackPanel>

                </Border>

                <Border Background="#1E293B"
                        CornerRadius="15"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="Chat IA"
                       Foreground="#CBD5E1"/>

                                <TextBlock Text="0"
                       FontSize="40"
                       FontWeight="Bold"
                       Foreground="White"  
                       Name="txtChatIA"
                       />

                    </StackPanel>

                </Border>

            </UniformGrid>

            <!-- CONTEÚDO NAVEGÁVEL -->

            <Border Grid.Row="1"
                    Background="#111827"
                    CornerRadius="20"
                    Padding="15" Margin="0,226,-154,-46" Grid.RowSpan="2">

                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden" Margin="-1,-5,-5,0" Navigated="MainFrame_Navigated"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>

            </Border>

        </Grid>

    </Grid>

</Window>
