<Page x:Class="WindowLobby.Pages.ConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">

            <Border Background="#1E293B"
                    CornerRadius="20"
                    Padding="30"
                    MaxWidth="1000"
                    MinWidth="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Meu Perfil"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,30"/>

                    <!-- FOTO -->

                    <StackPanel HorizontalAlignment="Center">

                        <Border Width="150"
                                Height="150"
                                CornerRadius="0"
                                BorderBrush="#3B82F6"
                                BorderThickness="3">

                            <Image x:Name="imgPerfil"
                                   Stretch="Fill"/>
                        </Border>

                        <Button Content="Selecionar Foto"
                                Width="150"
                                Margin="0,15,0,0"
                                Click="BtnSelecionarFoto_Click"/>

                    </StackPanel>

                    <!-- NOME -->

                    <TextBlock Text="Nome"
                               Foreground="White"
                               Margin="0,30,0,5"/>

                    <TextBox x:Name="txtNome"
                             Height="35"
                             FontSize="14"/>

                    <!-- BOTÃO -->

                    <Button Content="Salvar Alterações"
                            Height="40"
                            Margin="0,30,0,0"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="BtnSalvar_Click"/>

                    <TextBlock x:Name="txtStatus"
                               Foreground="LightGreen"
                               Margin="0,15,0,0"/>

                </StackPanel>

            </Border>

        </Grid>
    </ScrollViewer>
</Page>
